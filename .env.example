# ─── AURA — variables de entorno ──────────────────────────────────────
# Copia este archivo a .env y edita los valores antes de ejecutar Docker.
# NUNCA subas .env a Git.

# ══════════════════════════════════════════════════════════════════════
# PRODUCCIÓN (Docker en servidor)
# ══════════════════════════════════════════════════════════════════════
#
# VITE_API_URL=/api
#   El nginx del contenedor frontend proxea /api/ → backend:3000.
#   Frontend y API comparten el mismo dominio/puerto → sin problemas CORS.
#   ✅ Valor recomendado para Docker.
#
# VITE_API_URL=https://api.tudominio.com
#   Si el backend corre en un subdominio o servidor separado.
#   En ese caso ajusta CORS_ORIGIN con la URL del frontend.

# ── Frontend ──────────────────────────────────────────────────────────
PORT=8080
BASE_PATH=/
VITE_API_URL=/api

# ══════════════════════════════════════════════════════════════════════
# DESARROLLO LOCAL (npm run dev)
# ══════════════════════════════════════════════════════════════════════
#
# vite.config.js ya tiene proxy /api/ → http://localhost:3001
# por lo que en dev tampoco hace falta cambiar VITE_API_URL.
# Solo asegúrate de que el backend esté corriendo:
#   cd backend && npm install && node src/index.js
#   (o docker compose up backend postgres)
#
# Si el backend escucha en otro puerto, ajusta:
# VITE_API_URL_DEV=http://localhost:3001

# ── Backend ───────────────────────────────────────────────────────────
BACKEND_PORT=3001

# Secreto para JWT — cambia por una cadena larga y aleatoria:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_LARGO_Y_ALEATORIO

# CORS: usa el dominio real del frontend. Si frontend y API comparten dominio
# mediante VITE_API_URL=/api, puedes dejar este mismo dominio público.
CORS_ORIGIN=https://aura.tudominio.com

# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_USER=aura
POSTGRES_PASSWORD=aurapass
POSTGRES_DB=auradb
