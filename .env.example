# ─── Backend propio (Docker + Nginx) ───────────────────────────────────────
# URL base del servidor backend cuando esté desplegado.
# Ejemplos:
#   http://localhost:3000          (desarrollo local)
#   https://api.auraconecta.com   (producción)
# Dejar vacío para usar solo el store local (modo offline/demo).
VITE_API_URL=

# ─── Firebase (opcional, si se mantiene para auth/storage) ─────────────────
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
